Create/update .claude/settings.json:

{
  "mcpServers": {
    "context-mode": {
      "command": "context-mode"
    },
    "fallow": {
      "command": "npx",
      "args": ["-y", "fallow-mcp"]
    },
    "claude-mem": {
      "command": "npx",
      "args": ["-y", "claude-mem", "serve"]
    },
    "hermes": {
      "command": "hermes",
      "args": ["mcp", "serve"]
    }
  },
  "env": {
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "600000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "65"
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Read(.env)",
      "Read(**/.env*)"
    ],
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(fallow:*)",
      "Bash(context-mode:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE 'rm -rf|sudo|DROP TABLE|truncate'; then echo 'BLOCKED: dangerous command detected'; exit 2; fi"
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{
          "type": "command",
          "command": "npx eslint --fix \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
        }]
      }
    ]
  }
}

